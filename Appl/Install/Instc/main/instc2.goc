	month += 7; 	while (month >= 12) month -= 12;
	day += 9; 	while (day >= 28) day -= 28;
	h += 11;	while (h >= 24) h -= 24;
	min += 27;	while (min >= 60) min -= 60;
	sek2 += 17;	while (sek2 >= 30) sek2 -= 30;

	fdat2 =   (year << FDAT_YEAR_OFFSET)
		+ (month+1 << FDAT_MONTH_OFFSET)
		+ (day+1 << FDAT_DAY_OFFSET)
		+ (h << FDAT_HOUR_OFFSET)
