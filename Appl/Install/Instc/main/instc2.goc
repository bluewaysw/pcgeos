//	year += 13;	while (year >= 62) year -= 62;
//	month += 7; 	while (month >= 12) month -= 12;
	day += 1; 	while (day >= 28) day -= 28;
	h = 0;	while (h >= 24) h -= 24;
			while (h < 0) h += 24;
//	min += 27;	while (min >= 60) min -= 60;
//	sek2 += 1;	while (sek2 >= 30) sek2 -= 30;


