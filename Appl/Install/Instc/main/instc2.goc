	deltaMinutes2 = 0;
	CompareFileDateAndTime(fdat1, fdat1, &deltaMinutes2);
	CompareFileDateAndTime(fdat1, fdat1, &deltaMinutes1);
*/

	deltaMinutes1 = 0;
	deltaMinutes2 = 0;

	ret2 = CompareFileDateAndTimeNeu(fdat1, fdat2, &deltaMinutes2);
	ret1 = CompareFileDateAndTime(fdat1, fdat2, &deltaMinutes1);

