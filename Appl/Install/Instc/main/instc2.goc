@call ICFReleaseStatusText::MSG_VIS_TEXT_REPLACE_ALL_PTR(buf, 0);
sprintf(buf, "m2: %ld", deltaMinutes2);
@call ICFUserNotesStatusText::MSG_VIS_TEXT_REPLACE_ALL_PTR(buf, 0);
}/**/

	if ( ret1 != ret2 ) {
		DebugInfo2("¥rret difers: %d ->%d", ret1, ret2);
		DebugInfo2DW("¥rminutes: %ld ->%ld", deltaMinutes1, deltaMinutes2);
		err = TRUE;
		break;
	}
	if ( deltaMinutes1 != deltaMinutes2) {
		DebugInfo2DW("¥rBAD: %ld ->%ld", deltaMinutes1, deltaMinutes2);
		err = TRUE;
		break;
	}

	dep2 = FloatDepth();
	if ( dep != dep2) {
		DebugInfo2("¥rFlaotStack: %d ->%d", dep, dep2);
		err = TRUE;
		break;
	}

    }
    if (err) break;

DebugInfo("-");
h = 23;
	fdat1 =   (year << FDAT_YEAR_OFFSET)
		+ (month+1 << FDAT_MONTH_OFFSET)
		+ (day+1 << FDAT_DAY_OFFSET)
		+ (h << FDAT_HOUR_OFFSET)
		+ (min << FDAT_MINUTE_OFFSET)
