#include "math.h"

void CalcJD(int year, int month, int day, int h, int min, int sek, long double *jdPtr);
int CompareFileDateAndTime(FileDateAndTime fdat1, FileDateAndTime fdat2, dword *deltaMinutes);
word InternalCompareFileDateAndTime(FileDateAndTime fdat1, FileDateAndTime fdat2);

void CalcJDNeu(int year, int month, int day, int h, int min, int sek, FloatNum *jdFNPtr);
int CompareFileDateAndTimeNeu(FileDateAndTime fdat1, FileDateAndTime fdat2, dword *deltaMinutes);

/*
 * +++++++++++++++++++++++++++++++++++++++++++++++++++++
 */

void TestJulDat() {
double jd1, jd2, diff;
int year, month, day, h, min, sek;
word n, k;
FloatNum	fNum;
Boolean err = FALSE;

    year = 101;
    month = 7;
    day = 12;
    h = 17;
    min = 11;
    sek = 37;

for (n = 0; n < 20; n++ ) {
DebugInfo(".");
    for (k = 0; k < 1000; k++) {

	year += 17;	if (year >= 3500) year -= 3500;
	month += 5; 	if (month >= 12) month -= 12;
	day += 13; 	if (day >= 28) day -= 28;
	h += 9;		if (h >= 24) h -= 24;
	min += 37;	if (min >= 60) min -= 60;
	sek += 43;	if (sek >= 60) sek -= 60;

	CalcJD(year, month, day, h, min, sek, &jd1);
	CalcJDNeu(year, month, day, h, min, sek, &fNum);

	FloatPushNumber(&fNum);
	FloatGeos80ToIEEE64(&jd2);

	diff = jd1 - jd2;
	if ( diff < 0 ) diff = -diff;
	if ( diff > 1e-9 ) {
//	if ( diff != 0 ) {
	//if ( jd1 != jd2) {
		DebugInfo2("¥rBAD: n = %u, k=%u", n ,k);
		err = TRUE;
		break;
	}

    }
    if (err) break;
}


DebugInfo("¥rTestJulDat fertig.¥r");
}

