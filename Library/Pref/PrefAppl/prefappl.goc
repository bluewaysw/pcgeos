    GIGI_behaviorType = GIGBT_EXCLUSIVE;

    GIGI_destination = @BaseBox;
    GDLI_queryMsg = MSG_PREF_APPL_LEFT_LIST_MONIKER_QUERY;
    GDLI_numItems = 0;
    ATTR_GEN_ITEM_GROUP_CUSTOM_DOUBLE_PRESS =
        MSG_PREF_APPL_LEFT_LIST_DOUBLE_PRESS;

    HINT_PLACE_MONIKER_ABOVE;
    HINT_ITEM_GROUP_SCROLLABLE;
    HINT_INITIAL_SIZE = {
        SST_AVG_CHAR_WIDTHS | 28,
        SST_LINES_OF_TEXT | 12,
        12
