@include <stdapp.goh>
@include <config.goh>

#include "prefapplScan.h"
#include <Ansi/string.h>
#include <Ansi/stdio.h>

@class PrefApplDialogClass, PrefDialogClass;
    @instance word PADI_lastSelectedId = GIGS_NONE;

@message (GEN_ITEM_GROUP_APPLY_MSG) MSG_PREF_APPL_TAB_SELECTION_CHANGED;
@message (GEN_DYNAMIC_LIST_QUERY_MSG) MSG_PREF_APPL_LIST_MONIKER_QUERY;
@message (GEN_ITEM_GROUP_STATUS_MSG) MSG_PREF_APPL_LIST_SELECTED;
@message (GEN_TRIGGER_ACTION) MSG_PREF_APPL_RESCAN;
@message void MSG_PREF_APPL_SHOW_ERROR(PrefApplError paError);
@message PrefApplError MSG_PREF_APPL_REFRESH_LIST_FROM_DISK();

@endc

@classdecl PrefApplDialogClass;

optr _pascal PrefGetOptrBox(void);
void _pascal PrefGetModuleInfo(PrefModuleInfo *info);

word OldSelection = GIGS_NONE;
static const char prefApplDistApplMissingText[] =
    "Required folder SP_SYS_APPLICATION\\DISTAPPL was not found.\n"
    "PrefAppl cannot build the application list.";
static const char prefApplOutOfMemoryText[] =
    "PrefAppl ran out of memory while scanning applications.";
static const char prefApplStatusTextOk[] = "Ok";
static const char prefApplOperationSuccessText[] =
    "Application link operation finished successfully.";
static const char prefApplOperationPartialFailureText[] =
    "Application link operation finished with errors.";

@start MONIKERRESOURCE, data;

@include <Art/moniker.goh>

@visMoniker PrefApplTextMoniker = "Apps";

@visMoniker PrefApplMonikerList = list {
    @Moniker0,
    @Moniker1,
    @Moniker2,
    @Moniker3,
    @PrefApplTextMoniker
};

@end MONIKERRESOURCE;

@start BASEINTERFACE, notDetachable;

@object PrefApplDialogClass BaseBox = {
    GI_visMoniker = "Applications";
    GI_states = @default & ~GS_USABLE;
    GI_comp = @TabHolder;

    HINT_INTERACTION_COMPLEX_PROPERTIES;
    HINT_ORIENT_CHILDREN_VERTICALLY;
    HINT_EXPAND_WIDTH_TO_FIT_PARENT;
    HINT_EXPAND_HEIGHT_TO_FIT_PARENT;
    ATTR_GEN_HELP_CONTEXT = "dbApps";
    ATTR_GEN_INIT_FILE_CATEGORY = "prefappl";
}

@object GenInteractionClass TabHolder = {
    GI_comp = @TabSelector, @TabGroup;

    HINT_MINIMIZE_CHILD_SPACING;
    HINT_ORIENT_CHILDREN_VERTICALLY;
    HINT_EXPAND_WIDTH_TO_FIT_PARENT;
    HINT_EXPAND_HEIGHT_TO_FIT_PARENT;
}

@object GenItemGroupClass TabSelector = {
    GI_comp = @EnsembleAppsTab;
    GIGI_selection = 0;
    GIGI_destination = @BaseBox;
    GIGI_applyMsg = MSG_PREF_APPL_TAB_SELECTION_CHANGED;

    HINT_ITEM_GROUP_TAB_STYLE;
    HINT_ITEM_GROUP_DONT_CENTER_TABBED_CHILDREN;
    HINT_ORIENT_CHILDREN_HORIZONTALLY;
    HINT_EXPAND_WIDTH_TO_FIT_PARENT;
}

@object GenItemClass EnsembleAppsTab = {
    GI_visMoniker = "Ensemble Apps";
    GII_identifier = 0;
}

@object GenInteractionClass TabGroup = {
    GI_comp = @EnsembleAppsPage;

    HINT_CENTER_CHILDREN_HORIZONTALLY;
    HINT_CENTER_CHILDREN_VERTICALLY;
    HINT_EXPAND_WIDTH_TO_FIT_PARENT;
    HINT_EXPAND_HEIGHT_TO_FIT_PARENT;
    HINT_RAISED_FRAME = { GRFI_LEFT | GRFI_RIGHT | GRFI_BOTTOM };
    HINT_DRAW_IN_BOX;
}

@object GenInteractionClass EnsembleAppsPage = {
    GI_comp = @MainRow, @StatusText;

    HINT_EXPAND_WIDTH_TO_FIT_PARENT;
    HINT_EXPAND_HEIGHT_TO_FIT_PARENT;
    HINT_ORIENT_CHILDREN_VERTICALLY;
}

@object GenInteractionClass MainRow = {
    GI_comp = @AppList, @ActionColumn;

    HINT_ORIENT_CHILDREN_HORIZONTALLY;
    HINT_MINIMIZE_CHILD_SPACING;
    HINT_CENTER_CHILDREN_VERTICALLY;
    HINT_EXPAND_WIDTH_TO_FIT_PARENT;
    HINT_EXPAND_HEIGHT_TO_FIT_PARENT;
}

@object GenDynamicListClass AppList = {
    GI_visMoniker = "Applications:";

    GIGI_behaviorType = GIGBT_EXCLUSIVE_NONE;
    GIGI_selection = GIGS_NONE;
    GIGI_numSelections = 0;

    GIGI_destination = @BaseBox;
    GDLI_queryMsg = MSG_PREF_APPL_LIST_MONIKER_QUERY;
    GDLI_numItems = 0;

    ATTR_GEN_ITEM_GROUP_STATUS_MSG = MSG_PREF_APPL_LIST_SELECTED;
    HINT_PLACE_MONIKER_ABOVE;
    HINT_ITEM_GROUP_SCROLLABLE;
    HINT_INITIAL_SIZE = {
        SST_AVG_CHAR_WIDTHS | 36,
        SST_LINES_OF_TEXT | 12,
        12
    };
    HINT_EXPAND_HEIGHT_TO_FIT_PARENT;
}

@object GenInteractionClass ActionColumn = {
    GI_comp = @RescanTrigger;

    HINT_ORIENT_CHILDREN_VERTICALLY;
    HINT_CENTER_CHILDREN_HORIZONTALLY;
    HINT_FULL_JUSTIFY_CHILDREN_HORIZONTALLY;
    HINT_EXPAND_HEIGHT_TO_FIT_PARENT;
}

@object GenTriggerClass RescanTrigger = {
    GI_visMoniker = "Refresh";
    GTI_actionMsg = MSG_PREF_APPL_RESCAN;
    GTI_destination = @BaseBox;
}

@object GenGlyphClass StatusText = {
    GI_visMoniker = "Status:";
}

@end BASEINTERFACE;

@define Dup(obj) ConstructOptr(OptrToHandle(oself), OptrToChunk(obj))

optr _export _pascal PrefGetOptrBox(void)
{
    return (@BaseBox);
}

void _export _pascal PrefGetModuleInfo(PrefModuleInfo *modInfo)
{
    modInfo->PMI_requiredFeatures = PMF_USER;
    modInfo->PMI_prohibitedFeatures = 0;
    modInfo->PMI_minLevel = UIIL_INTRODUCTORY;
    modInfo->PMI_maxLevel = UIIL_MAX_LEVEL;

    modInfo->PMI_monikerList = @PrefApplMonikerList;
    modInfo->PMI_monikerToken.GT_chars[0] = 'P';
    modInfo->PMI_monikerToken.GT_chars[1] = 'A';
    modInfo->PMI_monikerToken.GT_chars[2] = 'P';
    modInfo->PMI_monikerToken.GT_chars[3] = 'L';
    modInfo->PMI_monikerToken.GT_manufID = MANUFACTURER_ID_GEOWORKS;
}

static void
PrefApplRefreshListMonikers(optr appList, word uiSelection)
{
    word appCount;

    appCount = PrefApplGetApplicationCount();
    @call appList::MSG_GEN_DYNAMIC_LIST_INITIALIZE(appCount);

    if (uiSelection == GIGS_NONE) {
        @call appList::MSG_GEN_ITEM_GROUP_SET_NONE_SELECTED(FALSE);
        return;
    }

    if (uiSelection >= appCount) {
        @call appList::MSG_GEN_ITEM_GROUP_SET_NONE_SELECTED(FALSE);
        return;
    }

    /*
     * Keep the transient UI selection in sync with the user's click while
     * the monikers are re-queried from the refreshed scan data.
     */
    @call appList::MSG_GEN_ITEM_GROUP_SET_SINGLE_SELECTION(uiSelection, FALSE);
}

@method PrefApplDialogClass, MSG_PREF_APPL_SHOW_ERROR
{
    const char *statusMessage = NULL;

    switch (paError) {
        case PREF_APPL_SCAN_ERROR_DISTAPPL_MISSING:
            statusMessage = prefApplDistApplMissingText;
            break;
        case PREF_APPL_SCAN_ERROR_OUT_OF_MEMORY:
            statusMessage = prefApplOutOfMemoryText;
            break;
        case PREF_APPL_OPERATION_SUCCESS:
            statusMessage = prefApplOperationSuccessText;
            break;
        case PREF_APPL_OPERATION_PARTIAL_FAILURE:
            statusMessage = prefApplOperationPartialFailureText;
            break;
        default:
            statusMessage = NULL;
            break;
    }

    if (statusMessage == NULL) {

        @call @Dup(@StatusText)::MSG_GEN_REPLACE_VIS_MONIKER_TEXT(prefApplStatusTextOk, VUM_NOW);
        return;
    }

    @call @Dup(@StatusText)::MSG_GEN_REPLACE_VIS_MONIKER_TEXT(statusMessage, VUM_NOW);
}

@method PrefApplDialogClass, MSG_PREF_APPL_REFRESH_LIST_FROM_DISK
{
    PrefApplError paError;
    word appCount;

    pself->PADI_lastSelectedId = GIGS_NONE;
    paError = PREF_APPL_ERROR_NONE;
    if (!PrefApplRefreshApplicationData()) {
        paError = PrefApplGetLastScanError();
    }

    appCount = PrefApplGetApplicationCount();
    @call @Dup(@AppList)::MSG_GEN_DYNAMIC_LIST_INITIALIZE(appCount);
    @call @Dup(@AppList)::MSG_GEN_ITEM_GROUP_SET_NONE_SELECTED(FALSE);
    return paError;
}

@method PrefApplDialogClass, MSG_GEN_INTERACTION_INITIATE
{
    PrefApplError paError;

    pself->PADI_lastSelectedId = GIGS_NONE;
    @callsuper();
    @call @Dup(@TabSelector)::MSG_GEN_ITEM_GROUP_SEND_STATUS_MSG(FALSE);
    paError = @call oself::MSG_PREF_APPL_REFRESH_LIST_FROM_DISK();
    @call oself::MSG_PREF_APPL_SHOW_ERROR(paError);
}

@method PrefApplDialogClass, MSG_PREF_APPL_TAB_SELECTION_CHANGED
{
    optr tabPages[] = {
        @EnsembleAppsPage
    };

    if (selection >= (sizeof(tabPages) / sizeof(tabPages[0]))) {
        return;
    }

    if ((OldSelection != GIGS_NONE) && (selection == OldSelection)) {
        return;
    }

    if ((OldSelection != GIGS_NONE) &&
        (OldSelection < (sizeof(tabPages) / sizeof(tabPages[0])))) {
        @call tabPages[OldSelection]::MSG_GEN_SET_NOT_USABLE(
            VUM_DELAYED_VIA_APP_QUEUE);
    }
    OldSelection = selection;
    @call tabPages[selection]::MSG_GEN_SET_USABLE(VUM_NOW);
}

@method PrefApplDialogClass, MSG_PREF_APPL_LIST_MONIKER_QUERY
{
    PrefApplApplicationRecord record;
    TCHAR buf[40] = {0};

    if (!PrefApplGetApplicationRecord(item, &record)) {
        return;
    }

    (record.PAAR_selected != 0) ? strcpy(buf, "\xA5\x20") : strcpy(buf, "\xCA\xCA");
    strcat(buf, record.PAAR_name);
    @call list::MSG_GEN_DYNAMIC_LIST_REPLACE_ITEM_TEXT(item, buf);
}

@method PrefApplDialogClass, MSG_PREF_APPL_LIST_SELECTED
{
    PrefApplApplicationRecord record;
    word appCount;
    word workingSelection;
    word uiSelection;
    Boolean hadErrors;
    Boolean newSelectedState;
    PrefApplError status;

    appCount = 0;
    workingSelection = selection;
    uiSelection = selection;
    hadErrors = FALSE;
    newSelectedState = FALSE;
    status = PREF_APPL_OPERATION_SUCCESS;

    @call @Dup(@AppList)::MSG_GEN_SET_NOT_ENABLED(VUM_NOW);

    appCount = PrefApplGetApplicationCount();
    if (workingSelection != GIGS_NONE) {
        pself->PADI_lastSelectedId = workingSelection;
    } else {
        if ((pself->PADI_lastSelectedId == GIGS_NONE) ||
            (pself->PADI_lastSelectedId >= appCount)) {
            pself->PADI_lastSelectedId = GIGS_NONE;
            @call @Dup(@AppList)::MSG_GEN_SET_ENABLED(VUM_NOW);
            return;
        }

        workingSelection = pself->PADI_lastSelectedId;
        pself->PADI_lastSelectedId = GIGS_NONE;
    }

    if ((workingSelection >= appCount) ||
        !PrefApplGetApplicationRecord(workingSelection, &record)) {
        pself->PADI_lastSelectedId = GIGS_NONE;
        @call @Dup(@AppList)::MSG_GEN_SET_ENABLED(VUM_NOW);
        return;
    }

    newSelectedState = (record.PAAR_selected == FALSE);
    if (!PrefApplSetApplicationSelected(workingSelection, newSelectedState)) {
        hadErrors = TRUE;
        goto updateList;
    }
    record.PAAR_selected = newSelectedState;

    if (record.PAAR_selected) {
        if (!PrefApplCreateApplicationLink(&record)) {
            hadErrors = TRUE;
            if (PrefApplSetApplicationSelected(workingSelection, FALSE)) {
                record.PAAR_selected = FALSE;
            }
        } else if (!PrefApplAddScannedApplicationLink(&record)) {
            hadErrors = TRUE;
        }
    } else {
        if (!PrefApplDeleteScannedLinksForToken(&record.PAAR_token)) {
            hadErrors = TRUE;
        }
        PrefApplRemoveScannedLinksForToken(&record.PAAR_token);
    }

updateList:
    PrefApplRefreshListMonikers(@Dup(@AppList), uiSelection);
    if (hadErrors) {
        status = PREF_APPL_OPERATION_PARTIAL_FAILURE;
    }
    @call oself::MSG_PREF_APPL_SHOW_ERROR(status);
    @call @Dup(@AppList)::MSG_GEN_SET_ENABLED(VUM_NOW);
}

@method PrefApplDialogClass, MSG_PREF_APPL_RESCAN
{
    PrefApplError paError;

    paError = @call oself::MSG_PREF_APPL_REFRESH_LIST_FROM_DISK();
    @call oself::MSG_PREF_APPL_SHOW_ERROR(paError);
}
