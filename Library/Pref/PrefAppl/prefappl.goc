@include <stdapp.goh>
@include <config.goh>
@include <token.h>

#include "prefapplLow.h"
#include <graphics.h>
#include <gstring.h>
#include <lmem.h>

@class PrefApplDialogClass, PrefDialogClass;
    @message (GEN_ITEM_GROUP_APPLY_MSG) MSG_PREF_APPL_TAB_SELECTION_CHANGED;
    @message (GEN_DYNAMIC_LIST_QUERY_MSG) MSG_PREF_APPL_LEFT_LIST_MONIKER_QUERY;
    @message (GEN_DYNAMIC_LIST_QUERY_MSG) MSG_PREF_APPL_RIGHT_LIST_MONIKER_QUERY;
    @message (GEN_ITEM_GROUP_APPLY_MSG) MSG_PREF_APPL_LEFT_LIST_DOUBLE_PRESS;
    @message (GEN_ITEM_GROUP_APPLY_MSG) MSG_PREF_APPL_RIGHT_LIST_DOUBLE_PRESS;
    @message (GEN_TRIGGER_ACTION) MSG_PREF_APPL_ADD_APPLICATION;
    @message (GEN_TRIGGER_ACTION) MSG_PREF_APPL_REMOVE_APPLICATION;
    @message void MSG_PREF_APPL_SET_STATUS_TEXT(const char *statusMessage);
    @message void MSG_PREF_APPL_SHOW_ERROR(PrefApplError paError);
    @message void MSG_PREF_APPL_QUEUE_REFRESH();
    @message PrefApplError MSG_PREF_APPL_REFRESH_LIST_FROM_DISK();
    @message void MSG_PREF_APPL_SET_CONTROL_STATE(Boolean enabled);
    @instance Boolean PADI_refreshQueued = FALSE;
    @instance Boolean PADI_refreshInProgress = FALSE;

@endc

@classdecl PrefApplDialogClass;

optr _pascal PrefGetOptrBox(void);
void _pascal PrefGetModuleInfo(PrefModuleInfo *info);

word OldSelection = GIGS_NONE;
static const char prefApplDistApplMissingText[] =
    "Required folder DISTAPPL was not found.\n"
    "PrefAppl cannot build the application list.";
static const char prefApplOutOfMemoryText[] =
    "PrefAppl ran out of memory while scanning applications.";
static const char prefApplStatusTextOk[] =
    "Ready.";
static const char prefApplEnabledText[] =
    "Application enabled.";
static const char prefApplEnablePartialFailureText[] =
    "Application enable finished with errors.";
static const char prefApplDisabledText[] =
    "Application disabled.";
static const char prefApplDisablePartialFailureText[] =
    "Application disable finished with errors.";

#define PREF_APPL_ICON_TEXT_SPACING 4

@start MONIKERRESOURCE, data;

@include "Art/PrefApplIcon.goh"

@visMoniker PrefApplTextMoniker = "Applications";

@visMoniker PrefApplMonikerList = list {
    @PrefApplIconMoniker,
    @PrefApplTextMoniker
};

@include    <Art/mkrRightArrowSC.goh>
@include    <Art/mkrRightArrowSM.goh>
@include    <Art/mkrRightArrowSCGA.goh>
@include    <Art/mkrLeftArrowSC.goh>
@include    <Art/mkrLeftArrowSM.goh>
@include    <Art/mkrLeftArrowSCGA.goh>

@end MONIKERRESOURCE;

@start BASEINTERFACE, notDetachable;

@object PrefApplDialogClass BaseBox = {
