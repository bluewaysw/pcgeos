		##
		##
		## DISTDOC directory, accessible via browser at
		## FILE:///GFS:/FREEGEOS/USERDATA/DISTDOC/docindex.htm
		## launchable from the PrefAppl Documents tab.
		## If you add documents here make sure they are also in GEOS/DOCUMENT
		## and in the handwritten document index html files in bbxensem/Userdata and
		## bbxensem/Userdata/german.
		##

		DIR (distdoc) {

			# our very own index files
			ENGLISH {
				Tools/build/product/bbxensem/Userdata/docindex.htm GFS
			}
			GERMAN {
				Tools/build/product/bbxensem/Userdata/german/docindex.htm GFS
			}

			# Readme
			Tools/build/product/bbxensem/Document/readme.txt GFS

			# Clip Art
			DIR (Clip Art) {
			ENGLISH {
				Tools/build/product/bbxensem/Document/CLIPART/BORDERS_.000 GFS
