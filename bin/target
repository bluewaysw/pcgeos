#!/bin/sh
##############################################################################
#
# 	Copyright (c) GeoWorks 1991 -- All Rights Reserved
#
# PROJECT:	PC GEOS
# MODULE:	target
# FILE: 	target
# AUTHOR: 	Falk Rehwagen, Oct 26, 2020
#
# REVISION HISTORY:
#	Name	Date		Description
#	----	----		-----------
#	fr	26/10/20	Initial Revision
#
# DESCRIPTION:
#	A script to start the target basebox and connect swat.
#
#	Usage: target [-n]
#
#	If you give the argument "-n", the target in gbuild.nc is launched,
#  otherwise the target in gbuild.
#
#	$Id: clean,v 1.18 97/02/12 17:08:40 stevey Exp $
#
###############################################################################
# Parse command line arguments
TYPE=ec
while [ "$#" -gt 0 ]; do
  case "$1" in
    -n)
      TYPE=nec
      ;;
  esac
  shift
done
if [ ! -f ${LOCAL_ROOT}/.bbxxip/.bbxxip.nt.${TYPE} ]; then
   echo "*** Target type ${TYPE} not built."
   exit 1
fi
eval $(cat ${LOCAL_ROOT}/.bbxxip/.bbxxip.nt.${TYPE})
GEOS_ROOT_REL=localpc/geos
if [ ! -f ${destdir}/${GEOS_ROOT_REL}/ENSEMBLE.BAT ]; then
   echo "*** Target at ${destdir} not usable."
   exit 1
fi
# Manual verification checklist after launcher/root-path changes:
# 1. C:\LOCALPC\GEOS is reachable and GEOS boots.
# 2. C:\IMAGE (or other gbuild siblings) is reachable from DOS/GEOS.
# 3. ${destdir}/localpc/IPX_STAT.TXT appears and Swat connects.
# 4. init.bat generation still appends swatgo and swatgo flow works.
if [ "$BASEBOX" = "" ]; then
    BASEBOX=dosbox
fi
OLD_PATH=$PWD
cd ${destdir}
rm ${destdir}/localpc/IPX_STAT.TXT
rm ${GEOS_ROOT_REL}/init.bat
if [ "$GEOS_CENTRAL_STORAGE" != "" ]; then
   echo mount s: %GEOS_CENTRAL_STORAGE% >> ${GEOS_ROOT_REL}/init.bat
fi
if [ "$GEOS_CDROM_DRIVE" != "" ]; then
   if [ -f "$GEOS_CDROM_DRIVE" ]; then
      echo imgmount r "$GEOS_CDROM_DRIVE" -t iso >> ${GEOS_ROOT_REL}/init.bat
   else
      echo mount r $GEOS_CDROM_DRIVE -t cdrom >> ${GEOS_ROOT_REL}/init.bat
   fi
fi
if [ -f "${GEOS_ROOT_REL}/init.bat" ]; then
   echo swatgo >> ${GEOS_ROOT_REL}/init.bat
fi
if [ -f "${GEOS_ROOT_REL}/privdata/INI.BAK" ]; then
   perl -pi -e 's{C:\\GEOS\\GFS\.IMG}{C:\\IMAGE\\GFS.IMG}ig; s{C:\\GEOS\\NETEC\.INI}{C:\\LOCALPC\\GEOS\\NETEC.INI}ig; s{C:\\GEOS\\NET\.INI}{C:\\LOCALPC\\GEOS\\NET.INI}ig; s{bootstrapPath\s*=\s*C:\\GEOS\b}{bootstrapPath = C:\\LOCALPC\\GEOS}ig;' "${GEOS_ROOT_REL}/privdata/INI.BAK"
fi
set -m
$BASEBOX -conf $ROOT_DIR/bin/basebox.conf -conf $LOCAL_ROOT/basebox_user.conf >/dev/null 2>&1 &
set +m
cd $OLD_PATH

clear
while [ ! -f ${destdir}/localpc/IPX_STAT.TXT ]; do sleep 1; printf "."; done
IPX_PORT=$(grep "127.0.0.1 from port" ${destdir}/localpc/IPX_STAT.TXT | perl -e 'my $status = <>; $status =~  m/(\d+)\r/; printf("%04X", $1);')
swat -net 00000000:7F000001${IPX_PORT}:003F
